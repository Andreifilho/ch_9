#include <iostream>
using namespace std;

struct result_record
{
    int total;
    float average;
};

result_record calculate_result(int mark1, int mark2, int mark3)
{
    result_record result;

    result.total = mark1 + mark2 + mark3;
    result.average = result.total / 3.0;

    return result;
}

int main()
{
    int m1, m2, m3;

    cin >> m1;
    cin >> m2;
    cin >> m3;

    result_record res = calculate_result(m1, m2, m3);

    cout << "Total: " << res.total << endl;
    cout << "Average: " << res.average << endl;

    return 0;
}
